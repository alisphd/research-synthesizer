{
  "entities": {
    "PaperAnalysis": {
      "title": "Paper Analysis",
      "description": "An analyzed research paper belonging to a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the paper" },
        "title": { "type": "string", "description": "Title of the paper" },
        "authors": { "type": "array", "items": { "type": "string" }, "description": "List of authors" },
        "year": { "type": "string", "description": "Publication year" },
        "journal": { "type": "string", "description": "Name of the journal or conference" },
        "summary": { "type": "string", "description": "Concise summary of the study" },
        "uniqueFindings": { "type": "array", "items": { "type": "string" }, "description": "Unique findings of the paper" },
        "gaps": { "type": "array", "items": { "type": "string" }, "description": "Research gaps mentioned in the paper" },
        "futureDirections": { "type": "array", "items": { "type": "string" }, "description": "Future research directions suggested" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Topic tags or keywords for the paper" },
        "createdAt": { "type": "timestamp", "description": "When the paper was added" }
      },
      "required": ["id", "title", "authors", "year", "journal", "summary", "uniqueFindings", "gaps", "futureDirections", "tags", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}/papers/{paperId}": {
      "schema": { "$ref": "#/entities/PaperAnalysis" },
      "description": "Papers analyzed and saved by a specific user."
    }
  }
}
